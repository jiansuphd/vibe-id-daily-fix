---
layout: base.njk
title: Dashboard
---
<main class="content" id="main-content">
  {% if collections.posts.length > 0 %}
    {% set latestPost = collections.posts[0] %}
    <article>
      <header>
        <h1><a href="{{ latestPost.url | url }}">{{ latestPost.data.title }}</a></h1>
        <div class="post-meta">
          <time datetime="{{ latestPost.date }}">{{ latestPost.date | dateFilter }}</time>
        </div>
      </header>
      {{ latestPost.templateContent | safe }}
    </article>
  {% else %}
    <p>No transmissions found. System standby.</p>
  {% endif %}
</main>

