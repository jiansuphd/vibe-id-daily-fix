<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | VibeID Daily</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <header class="hud">
    <div class="hud-logo">
      <a href="{{ '/' | url }}">VibeID Daily</a>
      <div class="hud-tagline">Tracking the journey from Natural Language to Systemic Automation.</div>
    </div>
    <div class="hud-metrics">
      <div class="metric">
        <span class="metric-label">STATUS</span>
        <span>ONLINE</span>
      </div>
      <div class="metric">
        <span class="metric-label">VERSION</span>
        <span>2026.04.29</span>
      </div>
      <div class="metric">
        <span class="metric-label">REGION</span>
        <span>EARTH_01</span>
      </div>
    </div>
  </header>

  <div class="dashboard-grid">
    {{ content | safe }}

    <aside class="sidebar">
      <div class="widget">
        <h3>About</h3>
        <p>The Vibe ID Daily - Tracking the journey from Natural Language to Systemic Automation.</p>
      </div>
      <div class="widget">
        <h3>Repository</h3>
        <p><a href="https://github.com/jiansuphd/vibe-id-daily">GitHub Repo</a></p>
      </div>
      <div class="widget">
        <h3>Archives</h3>
        <ul>
          {% for post in collections.posts %}
            <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </aside>
  </div>
</body>
</html>
