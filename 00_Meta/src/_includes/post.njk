---
layout: base.njk
---
<main class="content" id="main-content">
  <article>
    <header>
      <h1>{{ title }}</h1>
      <div class="post-meta">
        <time datetime="{{ date }}">{{ date | dateFilter }}</time>
      </div>
    </header>
    <div class="prose">
      {{ content | safe }}
    </div>
  </article>
</main>
