---
layout: base.njk
---
<div class="page-grid">
  <article>
    <header>
      <h1>{{ title }}</h1>
      <div class="post-meta">
        <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      </div>
    </header>
    <div class="prose">
      {{ content | safe }}
    </div>
    <div style="margin-top: 3rem;">
      <a href="{{ '/' | url }}" class="btn">&larr; Back to Latest</a>
    </div>
  </article>
</div>
