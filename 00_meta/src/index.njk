---
layout: base.njk
title: Latest Transmissions
---

<div class="dashboard-grid">
  <div class="content">
    {% if collections.posts.length > 0 %}
      {% for post in collections.posts | head(5) %}
      <article>
        <header>
          <h1><a href="{{ post.url | url }}">{{ post.data.title }}</a></h1>
          <div class="post-meta">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          </div>
        </header>
        <div class="prose">
          {{ post.templateContent | safe }}
        </div>
      </article>
      {% endfor %}
    {% else %}
      <p>No transmissions found. System standby.</p>
    {% endif %}
  </div>

  <aside class="sidebar">
    <div class="widget">
      <h3>// About</h3>
      <p>The Vibe ID Daily &mdash; Tracking the journey from Natural Language to Systemic Automation.</p>
    </div>
    <div class="widget">
      <h3>// Repository</h3>
      <ul>
        <li><a href="https://github.com/jiansuphd/vibe-id-daily" target="_blank" rel="noopener noreferrer">GitHub Repo</a></li>
        <li><a href="{{ '/archive/' | url }}">Full Archive</a></li>
        <li><a href="/vibe-id-daily/feed.xml">RSS Feed</a></li>
      </ul>
    </div>
    <div class="widget subscribe-widget">
      <h3>// Subscribe</h3>
      <p>Get new transmissions via email or RSS reader.</p>
      <form class="subscribe-form"
            action="https://api.follow.it/subscription-form/NnBnOFdoNUVmSzBYVUR0OXRodHh5dWlTQTV0d2FMRTlUVUJuZFA1VE1LVUtkWm4rY2l6UmsrNzJFenFwNFJzMUVGQ1pWbi9aZGdmMElRTi9UUklPa1BoS256R0phM1kxdGQveWlPZEg1RjcwVTV3aE5oV0RFbzBXcTI4SWxHMW58YjFGclowWVk2WFk2MlB6UTNsRjhMN2ZFQTdhbW51NU1ZeHFjdmM3VWp2TT0=/8"
            method="post"
            accept-charset="utf-8">
        <div class="subscribe-row">
          <input type="email" name="email" id="subscribe-email"
                 placeholder="you@example.com" required
                 aria-label="Email address for subscription">
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </div>
        <p class="subscribe-alt">Or copy the <a href="/vibe-id-daily/feed.xml">RSS feed URL</a> into your reader.</p>
      </form>
    </div>
    <div class="widget">
      <h3>// Start Here</h3>
      <p>New to the series? Begin at the entry point.</p>
      <ul>
        <li><a href="{{ '/posts/day-01-the-entry-point-protocol-agentsmd-geminimd/' | url }}">Day 1 &mdash; The Entry Point Protocol</a></li>
        <li><a href="{{ '/vibe-coding-intro/' | url }}">Full 100-Day Guide &rarr;</a></li>
      </ul>
    </div>
    <div class="widget">
      <h3>// The Vibe Coding Guide</h3>
      <p>100-day strategic pointer reference &mdash; from Workflow &amp; Control to Total Systemic Integration.</p>
      <a href="{{ '/vibe-coding-intro/' | url }}" class="subscribe-btn" style="display:inline-block;margin-top:0.5rem">Read the Guide &rarr;</a>
    </div>
    <div class="widget">
      <h3>// Archives</h3>
      <ul>
        {% for post in collections.posts | reverse | head(8) %}
        <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</div>
