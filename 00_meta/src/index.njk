---
layout: base.njk
title: Latest Transmissions
---

<div class="page-tagline">
  <span class="page-tagline-site">The Vibe ID Daily</span>
  <span class="page-tagline-sep">—</span>
  Tracking the journey from Natural Language to Systemic Automation.
</div>

<div class="dashboard-grid">
  <div class="content">
    {% if collections.posts.length > 0 %}
      {% for post in collections.posts | head(5) %}
      <article>
        <header>
          <h1><a href="{{ post.url | url }}">{{ post.data.title }}</a></h1>
          <div class="post-meta">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          </div>
        </header>
        <div class="prose">
          {{ post.templateContent | safe }}
        </div>
      </article>
      {% endfor %}
    {% else %}
      <p>No transmissions found. System standby.</p>
    {% endif %}
  </div>

  <aside class="sidebar">
    <div class="widget">
      <h3>// Navigation</h3>
      <ul>
        <li><a href="{{ '/' | url }}">Latest Transmissions</a></li>
        <li><a href="{{ '/archive/' | url }}">Full Archive</a></li>
        <li><a href="/feed.xml">RSS Feed</a></li>
        <li><a href="https://github.com/jiansuphd/vibe-id-daily" target="_blank" rel="noopener noreferrer">GitHub Repo</a></li>
      </ul>
    </div>
    <div class="widget">
      <h3>// Mission</h3>
      <p>Daily strategic pointers for Instructional Designers transitioning from natural language workflows to systemic agentic automation.</p>
    </div>
  </aside>
</div>
