---
layout: base.njk
title: Transmission Archive
permalink: /archive/
---

<div class="dashboard-grid">
  <div class="content">
    <div class="page-header">
      <h1>The Transmission Archive</h1>
      <p class="page-subtitle">A chronological history of strategic pointers for the Vibe ID.</p>
    </div>
    <div class="archive-list">
      {% for post in collections.posts | reverse %}
      <a href="{{ post.url | url }}" class="archive-item">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        <span class="archive-item-title">{{ post.data.title }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
  <aside class="sidebar">
    <div class="widget">
      <h3>// About</h3>
      <p>The Vibe ID Daily &mdash; Tracking the journey from Natural Language to Systemic Automation.</p>
    </div>
    <div class="widget subscribe-widget">
      <h3>// Subscribe</h3>
      <p>Get new transmissions via email or RSS reader.</p>
      <form class="subscribe-form"
            action="https://api.follow.it/subscription-form/dFJkZUhzZ0RMYXFMS2p5VVpLemhrUklSZHEybUpvQ21nWXptRDlPb0NUWlAydXNNMUhNbUkzUVZ2WVBZR1QwdXkwb1VEdThJblVzL3lwSkMrMVNvcWFSNjJ6Q2FsUlViendsTGZ0dThBTHJKd2N4NGFHZ2ZJREFiM1grUTZ8OFQ0TTFzSTF0eks4OXlYTGFCS1dFSDF1MUY2M2pSVWwxVmEwNjEvMkk2RT0=/8"
            method="post"
            accept-charset="utf-8">
        <div class="subscribe-row">
          <input type="email" name="email" id="subscribe-email"
                 placeholder="you@example.com" required
                 aria-label="Email address for subscription">
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </div>
        <p class="subscribe-alt">Or copy the <a href="/vibe-id-daily/feed.xml">RSS feed URL</a> into your reader.</p>
      </form>
    </div>
    <div class="widget">
      <h3>// Repository</h3>
      <ul>
        <li><a href="https://github.com/jiansuphd/vibe-id-daily" target="_blank" rel="noopener noreferrer">GitHub Repo</a></li>
      </ul>
    </div>
    <div class="widget">
      <h3>// Recent</h3>
      <ul>
        {% for post in collections.posts | reverse | head(6) %}
        <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</div>
