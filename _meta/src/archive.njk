---
layout: base.njk
title: Archive
permalink: /archive/
---

<h1>Transmission Archive</h1>

<ul style="list-style: none; padding: 0;">
    {% for post in collections.posts %}
    <li style="margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
        <span style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--secondary-color); margin-right: 1rem;">{{ post.date | readableDate }}</span>
        <a href="{{ post.url | url }}" style="font-weight: bold; text-decoration: none;">{{ post.data.title }}</a>
    </li>
    {% endfor %}
</ul>
